# Cloudflare R2 Configuration
# Get these values from your Cloudflare dashboard: https://dash.cloudflare.com/

# Your Cloudflare Account ID (found in R2 overview)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# R2 API credentials (create from R2 > Manage R2 API Tokens)
CLOUDFLARE_ACCESS_KEY_ID=your_access_key_id_here
CLOUDFLARE_SECRET_ACCESS_KEY=your_secret_access_key_here

# R2 Bucket name (create a bucket in R2 dashboard)
CLOUDFLARE_BUCKET_NAME=frames

# Public URL for your R2 bucket (with custom domain or default R2.dev URL)
# Example with custom domain: https://frames.yourdomain.com
# Example with R2.dev: https://pub-your_account_id.r2.dev
CLOUDFLARE_PUBLIC_URL=https://pub-your_account_id.r2.dev
