---
import { getImage } from "astro:assets";

type Props = {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: "eager" | "lazy";
  inferSize?: boolean;
  [key: string]: any;
};

const { src, alt, width, height, class: className, loading, inferSize, ...rest } = Astro.props;

// Check if we are in offline mode.
// You can set this in your .env file: PUBLIC_OFFLINE=true
const isOffline = import.meta.env.PUBLIC_OFFLINE === "true";

let finalWidth = width;
let finalHeight = height;

if (inferSize && !isOffline && (!finalWidth || !finalHeight)) {
  try {
    const inferred = await getImage({ src, inferSize: true });
    finalWidth = inferred.attributes.width;
    finalHeight = inferred.attributes.height;
  } catch (e) {
    console.error(`[RemoteImage] Failed to infer size for ${src}:`, e);
  }
}

// Default to lazy loading and async decoding if not specified
const finalLoading = loading || "lazy";
const finalDecoding = rest.decoding || "async";

// If width and height are not provided and inferSize is false, we might want defaults for the placeholder
const placeholderWidth = width || 800;
const placeholderHeight = height || 600;
---

{
  isOffline ? (
    <div class={`remote-image-placeholder ${className || ""}`} style={`width: ${width ? `${width}px` : "100%"}; height: ${height ? `${height}px` : "auto"}; aspect-ratio: ${width && height ? `${width}/${height}` : "16/9"}; background-color: #e0e0e0; display: flex; align-items: center; justify-content: center; color: #757575; font-family: monospace; font-size: 0.8rem; padding: 1rem; text-align: center;`} {...rest}>
      <span>[Offline] {alt}</span>
    </div>
  ) : (
    <img src={src} alt={alt} width={finalWidth} height={finalHeight} class={className} loading={finalLoading} decoding={finalDecoding} {...rest} />
  )
}
