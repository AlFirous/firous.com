---
import Grid from "../components/Grid.astro";
import Head from "../components/Head.astro";

import HeaderEditorial from "../components/HeaderEditorial.astro";
import FooterMinimal from "../components/FooterMinimal.astro";

import "../styles/global.css";
import "../styles/labs.css";

import { Font } from "astro:assets";
import { getCollection } from "astro:content";

const title = "Labs";
const description = "Multidisciplinary maker creating out of curiosity and things I wish existed. Experiment, exploration, or proof of concept. Unpolished and imperfect. No rules and boundaries. With or without limitations.";
const url = "/labs";

const labs = await getCollection("labs");

const getSlug = (id: string) => {
  return id.replace(/\.md$/i, "").toLowerCase().replace(/\s+/g, "-");
};
---

<html lang="en">
  <Head title={title} description={description} url={url}>
    <Font slot="in-head" cssVariable="--font-editorial-new" preload />
    <Font slot="in-head" cssVariable="--font-neue-montreal" preload />
  </Head>
  <body>
    <HeaderEditorial />
    <main>
      <section class="labs-hero">
        <h1>{title}</h1>
        <p>Multidisciplinary maker creating out of curiosity and things I wish existed. Experiment, exploration, or proof of concept. Unpolished and imperfect. No rules and boundaries. With or without limitations.</p>
      </section>
      <section class="labs-gallery">
        {
          labs.map((project) => (
            <article>
              <a href={`/labs/${getSlug(project.id)}`}>
                <project-thumbnail />
                <project-title>
                  <h2>{project.data.title}</h2>
                  <p>{project.data.tags?.join(", ")}</p>
                </project-title>
              </a>
            </article>
          ))
        }
      </section>
    </main>
    <FooterMinimal />
    <Grid />
  </body>
</html>
