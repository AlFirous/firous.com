              <clipPath id="clip0_458_965">
                <rect width="205" height="174.37" fill="white"></rect>
              </clipPath>
            </defs>
          </svg>
        </h1>
        <p>A frame may have a story waiting to be told, even if it's just ordinary, plain, or mundane.</p>
        {
          featuredFrame && (
            <article class="featured">
              <!--<a href={`/frames/${getSlug(featuredFrame.id)}`}>-->
                {featuredFrame.data.image && <SmartImage src={featuredFrame.data.image} alt={featuredFrame.data.title} title={featuredFrame.data.title} loading="eager" decoding="sync" fetchpriority="high" transition:name={`image-${featuredFrame.id}`} />}
                <h2 transition:name={`title-${featuredFrame.id}`}>{featuredFrame.data.title}</h2>
             <!-- </a>-->
            </article>
          )
        }
      </section>
      <section class="gallery">
        <filter-sort><filter-category>Photography/Videography</filter-category><sort-date>Taken/Published</sort-date></filter-sort>
        {
          galleryFrames.map((frame) => (
            <article>
              <a href={`/frames/${getSlug(frame.id)}`}>
                {frame.data.image && <SmartImage src={frame.data.image} inferSize={true} alt={frame.data.title} transition:name={`image-${frame.id}`} />}
                <h2 transition:name={`title-${frame.id}`}>{frame.data.title}</h2>
                {frame.data.taken && (
                  <time datetime={frame.data.taken.toISOString()} title="Date Taken">
                    {formatDate(frame.data.taken)}
                  </time>
                )}
              </a>
            </article>
          ))
        }
      </section>
    </main>
    <FramesFooter />
    <script>
      import "../scripts/hamburger.js";
    </script>
  </body>
</html>
