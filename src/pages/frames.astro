---
import { getCollection } from "astro:content";
import Head from "../components/Head.astro";
import HeaderMinimal from "../components/HeaderMinimal.astro";
import { Image } from "astro:assets";
import SmartImage from "../components/SmartImage.astro";

import FramesFooter from "../components/FramesFooter.astro";
import { ClientRouter } from "astro:transitions";

import "../styles/variables.css";
import "../styles/global.css";
import "../styles/frames.css";

import { Font } from "astro:assets";

const frames = await getCollection("frames");

// Sort frames by taken date descending
const sortedFrames = frames.sort((a, b) => {
  const dateA = a.data.taken ? new Date(a.data.taken).getTime() : 0;
  const dateB = b.data.taken ? new Date(b.data.taken).getTime() : 0;
  return dateB - dateA;
});

const featuredFrame = sortedFrames[0];
const galleryFrames = sortedFrames.slice(1);

const formatDate = (date: Date | string | number | undefined) => {
  if (!date) return "";
  const d = new Date(date);
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
  });
};

const getSlug = (id: string) => {
  return id.replace(/\.md$/i, "").toLowerCase().replace(/\s+/g, "-");
};
---

<html lang="en" class="index">
  <Head title="Frames" description="A frame may have a story waiting to be told, even if it's just ordinary, plain, or mundane." image={featuredFrame?.data.image || "https://firous.com/wp-content/uploads/2025/05/IMG_9744_KP800V4_SQU.jpg"}>
    <Font cssVariable="--font-museum" preload />
    <ClientRouter />
  </Head>
  <body>
    <HeaderMinimal>
      <a href="/frames">
          <svg width="5" height="24" viewBox="0 0 5 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4.8 2.4H2.4V21.6H4.8V24H0V0H4.8V2.4Z" fill="white"/>
          </svg>
          <svg width="5" height="24" viewBox="0 0 5 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4.8 24L4.8 6.20015e-08L2.09815e-06 -3.57628e-07L1.88833e-06 2.4L2.4 2.4L2.4 21.6L2.09815e-07 21.6L0 24L4.8 24Z" fill="white"/>
          </svg>

      </a>
    </HeaderMinimal>
    <main>
        <section class="hero">
            <h1 aria-label="Frames" title="Frames" transition:name="logo">
          <svg width="205" height="175" viewBox="0 0 205 175" fill="none" xmlns="http://www.w3.org/2000/svg">
