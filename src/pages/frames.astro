---
import Head from "../components/Head.astro";

import "../styles/global.css";
import "../styles/frames.css";

import { Font } from "astro:assets";
---

<html lang="en" class="index">
  <Head title="Frames" description="Hobby photography and cinematography by Al Firous" image="https://firous.com/wp-content/uploads/2025/05/IMG_9744_KP800V4_SQU.jpg">
    <Font slot="in-head" cssVariable="--font-editorial-new" preload />
    <Font slot="in-head" cssVariable="--font-neue-montreal" preload />
    <Head />
    <body>
      <main>
        <section class="frames-hero">
          <frames-title>
            <h1>
              <svg>
                <title>Frames</title>
              </svg>
            </h1>
            <p><span>Every</span> <span>frame</span> <span>may</span> <span>have</span> <span>a</span> <span>story</span></p>
            <p>Photography, videography and cinematography <span><em>by</em> Al Firous</span></p>
          </frames-title>
          <frames-featured>
            <article class="frames-featured">
              <a href="/">
                <img src="https://firous.com/wp-content/uploads/2025/05/IMG_9744_KP800V4_SQU.jpg" alt="Asian Green Lizard" />
                <h2>Curious Green Lizard</h2>
              </a>
            </article>
          </frames-featured>
        </section>
        <section class="frames-gallery">
          <article></article>
          <article></article>
          <article></article>
          <article></article>
          <article></article>
          <article></article>
          <article></article>
          <article></article>
          <article></article>
          <article></article>
          <article></article>
          <article></article>
        </section>
      </main>
    </body>
  </Head>
</html>
