---
import { getCollection } from "astro:content";

const music = (await getCollection("music")) || [];
const mixtapes = (await getCollection("mixtapes")) || [];

const recentTracks = music.filter((m) => m.data.type === "track") || [];
const topArtists = music.filter((m) => m.data.type === "artist") || [];
const topAlbums = music.filter((m) => m.data.type === "album") || [];

const nowPlaying = recentTracks.find((t) => t.data.nowPlaying);

const FALLBACK_IMAGE = "/icons/generic.svg"; // Ensure this exists or use a stylized div
---

<style>
  .music-container {
    margin: 0 auto;
    padding: 2rem;
    font-family: var(--font-inter, sans-serif);
  }

  section {
    margin-bottom: 4rem;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 0.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1.5rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
  }

  .card.is-track {
    text-align: center;
  }

  .cover {
    aspect-ratio: 1 / 1;
    background: #f4f4f4;
    overflow: hidden;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .cover.is-circle {
    border-radius: 50%;
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  /* Placeholder styling when image is missing or loading */
  .cover::before {
    content: "💿";
    font-size: 2rem;
    color: #ccc;
    position: absolute;
    z-index: 0;
  }

  .cover.is-circle::before {
    content: "♪";
  }

  .info {
    font-size: 0.9rem;
  }

  .title {
    font-weight: 600;
    display: block;
  }

  .subtitle {
    opacity: 0.7;
    font-size: 0.8rem;
  }

  .now-playing-banner {
    background: #f8f8f8;
    padding: 1rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    background: #ff4b4b;
    border-radius: 50%;
    display: inline-block;
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
    100% {
      opacity: 1;
    }
  }
  .hero {
    height: 60vh;
    width: 100%;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: #000;
    color: #fff;
    overflow: hidden;
    position: relative;
  }

  #spectrogram-canvas {
    width: 100%;
    height: 100vh;
    opacity: 0.4;
  }

  .hero-text {
    text-align: center;
    pointer-events: none;
    z-index: 10;
  }

  .hero-text h1 {
    font-size: 3rem;
    font-family: var(--font-garamond, serif);
    font-weight: 400;
    margin: 0;
  }
</style>

<div class="music-container">
  <div class="hero">
    <div class="hero-text">
      <h1>Music</h1>
      <p class="subtitle">Food for the soul</p>
    </div>
    <canvas id="spectrogram-canvas"></canvas>
  </div>

  {
    nowPlaying && (
      <div class="now-playing-banner">
        <div class="live-dot" />
        <div class="info">
          <span class="subtitle">Now Playing:</span>
          <span class="title">
            {nowPlaying.data.title} by {nowPlaying.data.artist}
          </span>
        </div>
      </div>
    )
  }

  <section>
    <h2>Mixtapes</h2>
    <div class="grid">
      {
        mixtapes.map((mixtape) => (
          <a href={mixtape.data.url} class="card" target="_blank">
            <div class="cover">
              <img src={mixtape.data.thumbnail || FALLBACK_IMAGE} alt={mixtape.data.title} />
            </div>
            <div class="info">
              <span class="title">{mixtape.data.title}</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section>
    <h2>Recently Played</h2>
    <div class="grid">
      {
        recentTracks.slice(0, 10).map((track) => (
          <a href={track.data.url} class="card is-track" target="_blank">
            <div class="cover is-circle">
              <img src={track.data.image || FALLBACK_IMAGE} alt={track.data.title} />
            </div>
            <div class="info">
              <span class="title">{track.data.title}</span>
              <span class="subtitle">{track.data.artist}</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section>
    <h2>Top Albums (Weekly)</h2>
    <div class="grid">
      {
        topAlbums.map((album) => (
          <a href={album.data.url} class="card" target="_blank">
            <div class="cover">
              <img src={album.data.image || FALLBACK_IMAGE} alt={album.data.title} />
            </div>
            <div class="info">
              <span class="title">{album.data.title}</span>
              <span class="subtitle">{album.data.artist}</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section>
    <h2>Top Artists (Weekly)</h2>
    <div class="grid">
      {
        topArtists.map((artist) => (
          <a href={artist.data.url} class="card" target="_blank">
            <div class="cover">
              <img src={artist.data.image || FALLBACK_IMAGE} alt={artist.data.name} />
            </div>
            <div class="info">
              <span class="title">{artist.data.name}</span>
              <span class="subtitle">{artist.data.playcount} scrobbles</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</div>

<script>
  import { initSpectrogram } from "../scripts/spectrogram";
  initSpectrogram("spectrogram-canvas");
</script>
